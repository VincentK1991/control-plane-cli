# Google Cloud OAuth 2.0 Client ID used by Google Identity Services.
# Create this in Google Cloud Console under APIs & Services > Credentials.
# For local development, add these Authorized JavaScript origins:
# - http://localhost:4321
# - http://127.0.0.1:4321
PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Server-side Google token verification. This should match PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Postgres connection string used by API routes.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/control_plane

# Temporal server (see `just temporal`) used to start the document-indexing
# pipeline from the per-database dashboard page.
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default

# Random secrets used for session signing and API-key hashing.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-64-hex-chars
API_KEY_PEPPER=replace-with-another-64-hex-chars

# Public app URL used for OAuth redirects and Stripe hosted pages.
PUBLIC_APP_URL=http://127.0.0.1:4321

# Stripe test-mode billing.
# Use a metered recurring Price ID and a Billing Meter event name.
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_METER_EVENT_NAME=mock_inference_tokens

# Optional local smoke-test key. Real keys are generated in the dashboard.
TEST_API_KEY=cp_live_replace_with_dashboard_generated_key

# Optional local smoke-test key. Real keys are generated in the dashboard.
MY_API_KEY=cp_live_replace_with_dashboard_generated_key