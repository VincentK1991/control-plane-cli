# Temporal server started via `docker compose up -d temporal temporal-ui`
# in the repo root. UI at http://localhost:8088.
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default

# Read-only access to the control-plane Postgres database (api_keys,
# neo4j_instances, users). Pipelines never write to this database directly;
# only through the activities defined in each workflow package.
CONTROL_PLANE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/control_plane

# Kubernetes context used to read per-instance Neo4j credentials, mirroring
# src/lib/dbaas/kubernetes.ts in the main app.
KUBECONFIG=/path/to/kubeconfig

# Used by the document-indexing pipeline's entity/relationship extraction
# (gpt-4o-mini) and the entity-normalization sweep's near-miss judgment calls.
OPENAI_API_KEY=